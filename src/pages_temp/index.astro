---
import H1 from "../components/h1.astro";
import Link from "../components/link.astro";
import Navigation from "../components/navigation";
import RootLayout from "../layouts/RootLayout.astro";
import WarpBackground from "../components/warp-background";
import AvailableForWork from "../components/available.astro";
---

<RootLayout>
	<main>
		<div class="group relative w-full min-h-dvh flex items-center justify-center">
			<div class="absolute w-full h-dvh -z-10">
				<WarpBackground
					color1="#000000"
					color2="#474747"
					color3="#000000"
					speed={0.3}
					swirl={0.2}
					swirlIterations={10}
					shapeScale={0.3}
					client:load
				/>
			</div>

			<div class="p-4 sm:p-8 absolute w-full h-dvh flex flex-col justify-between z-10">
				<div>
					<H1 size="large"> Rustem <br /> Akhunov </H1> 
					<p class="mt-2 text-base sm:text-lg opacity-70 font-light tracking-wide text-gray-200">
 Here begins the narrative of light and shadow, spun from the Creator’s breath. 
  I am merely the messenger.
</p>
				</div>

				<div>
					<AvailableForWork className="py-4" />
					<div class="mb-2 sm:mb-4 flex items-center justify-between">
						<div class="flex items-center gap-4">
							{/* Кнопка Cinematography ведет на страницу cinematography */}
							<Link href="/cinematography">Cinematography</Link> 
							{/* Кнопка Photography ведет на страницу photography */}
							<Link href="/photography" variant="secondary">Photography</Link>
						</div>

						<Navigation client:load>
							<Link href="/prints" variant="secondary">Prints</Link>
							<Link href="/about" variant="secondary">About</Link>
							<Link href="/contact" variant="secondary">Contact</Link>
						</Navigation>
					</div>
				</div>
			</div>
		</div>
	</main>
</RootLayout>