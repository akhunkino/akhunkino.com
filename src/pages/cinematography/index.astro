---
import clsx from "clsx";
import H1 from "../../components/h1.astro";
import InfoLayout from "../../layouts/InfoLayout.astro";

// Получаем категорию из URL
const videoSubcategoryFromURL = Astro.url.searchParams.get("sub");

// Единый объект с данными всех категорий видео
const videos = {
  reel: [
    { id: 'C0d3_8hNO3c', title: 'Filmmaker reel', description: '2022', category: 'reel' },
  ],
  travel: [
    { id: 'G6AxlXKHtiw', title: 'B E T² E P', description: 'The kiss of peace, in every breath of wind within us.', category: 'travel' },
    { id: 'glL904gLGxE', title: "We won't come back the same", description: 'Travel film from Russia and China', category: 'travel' },
    { id: 'FydexI8ZNWg', title: 'Temporal gradients', description: 'Travel film from the Philippines', category: 'travel' },
    { id: 'c9SXu0MtBBQ', title: 'One Minute More', description: 'Travel film from Turkey & Georgia', category: 'travel' },
    { id: '5IULC2mWuXw', title: 'Do u wanna be?', description: 'Travel film from Thailand', category: 'travel' },
    { id: 'CjJAa7h-oB4', title: 'Silent', description: 'Travel film from Murmansk, Russia', category: 'travel' },
    { id: 'Nv4RTo_tx_g', title: 'Dromomania', description: 'Travel film from the Caucasus', category: 'travel' },
    { id: 'Rk5pyxEnqEI', title: 'Light from the abyss', description: 'Having devoured a piece of the world, another attempt to fan a flame from a candle’s flicker.', category: 'travel' },
  ],
  commercial: [
    { id: 'JPEk1ZnsZkc', title: 'Activity Walker', description: '2024', category: 'commercial' },
    { id: 'NvO9PmtnfnM', title: 'Darvol', description: '2019', category: 'commercial' },
    { id: 'R5blsk0C5ns', title: 'Playmat', description: '2024', category: 'commercial' },
    { id: 'oo0P5WfWvRI', title: 'Insight Light', description: '2019', category: 'commercial' },
  ],
  documentary: [
    { id: 'Yli6qXVQP_k', title: 'Lu Yi Feng (陆奕峰)', description: 'told us about his dream and why he does not cook at home.', category: 'documentary' },
    { id: '-hu3wasroM4', title: 'Chinese New Year', description: 'A small story about a big story.', category: 'documentary' },
  ],
  fpv: [
    { id: '0R1GDyQ-sLU', title: 'Windmills', description: 'China 2025', category: 'fpv' },
    { id: 'kayxFvylGn8', title: 'Hong Kong', description: '2025', category: 'fpv' },
    { id: 'yKqwcE6VumM', title: 'Speculation', description: 'Cognition exploring the world', category: 'fpv' },
    { id: 'omDhj6XqklU', title: 'Does the heart age?', description: 'Картая мени соң йөрәк?', category: 'fpv' },
  ],
  "visual poetry": [
    { id: 'WBWQ_pI-5sw', title: 'Im Westen nichts Neues', description: 'Erich Maria Remarque', category: 'visual poetry' },
    { id: '3-aZy0471cI', title: 'Seafood street market', description: 'Street film from China', category: 'visual poetry' },
  ],
};

// Функция для получения случайной категории
function getRandomCategory(categories) {
  const keys = Object.keys(categories);
  const randomIndex = Math.floor(Math.random() * keys.length);
  return keys[randomIndex];
}

// Если в URL нет категории - выбираем случайную
const videoSubcategory = videoSubcategoryFromURL || getRandomCategory(videos);

// Функция для получения URL обложки - используем только hqdefault
function getThumbnailUrl(videoId) {
  // Всегда используем hqdefault - он есть у всех видео
  return `https://img.youtube.com/vi/${videoId}/hqdefault.jpg`;
}

// Функция перемешивания
function shuffleArray(array) {
  const shuffled = [...array];
  for (let i = shuffled.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
  }
  return shuffled;
}

// Перемешиваем все категории один раз
const shuffledVideos = {};
for (const [key, arr] of Object.entries(videos)) {
  shuffledVideos[key] = shuffleArray(arr);
}

// Активная категория с fallback
const validCategories = Object.keys(videos);
const activeCategory = validCategories.includes(videoSubcategory)
  ? videoSubcategory
  : getRandomCategory(videos); // Если категория из URL невалидна, тоже выбираем случайную
---

<InfoLayout>
  <!-- Основной контейнер с защитой от выделения -->
  <div class="p-4 sm:pt-8 sm:px-12 pb-20 min-h-dvh no-selection">
    <H1>Cinematography</H1>

    <!-- Кнопки категорий -->
    <div class="px-4 sm:px-12 mb-8 mt-8">
      <div class="flex items-center gap-4 flex-wrap">
        {validCategories.map((cat) => {
          const label =
            cat === "reel" ? "Showreel" :
            cat === "travel" ? "Travel Films" :
            cat === "commercial" ? "Commercial" :
            cat === 'documentary' ? 'Documentary' :
            cat === 'fpv' ? 'FPV' :
            cat === 'visual poetry' ? 'My Visual Poetry' : cat;

          return (
            <a
              href={`/cinematography?sub=${cat}`}
              class={clsx(
                'px-4 py-2 text-sm rounded-full transition-all duration-300 border no-selection',
                activeCategory === cat
                  ? 'bg-white text-black border-white'
                  : 'bg-zinc-800 text-zinc-300 hover:bg-zinc-700 border-transparent'
              )}
            >
              {label}
            </a>
          );
        })}
      </div>
    </div>

    <!-- Горизонтальный коллаж с видео (как на странице Photography) -->
    <div class="px-4 sm:px-12">
      <div class="overflow-x-auto">
        <div class="flex gap-4 pb-4 min-w-max">
          {shuffledVideos[activeCategory].map((video, index) => (
            <div
              key={`${activeCategory}-${index}`}
              class="flex-shrink-0 no-selection video-item"
            >
              <div class="relative overflow-hidden rounded-lg bg-zinc-800 no-selection video-container">
                <!-- Контейнер для видео превью с правильными пропорциями 16:9 -->
                <div class="w-auto h-[600px] aspect-video flex items-center justify-center relative group cursor-pointer" data-video-id={video.id}>
                  <img
                    src={getThumbnailUrl(video.id)}
                    alt={video.title}
                    class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
                    loading="lazy"
                    decoding="async"
                  />
                  
                  <!-- Overlay с кнопкой play и информацией в центре -->
                  <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-all duration-500 flex flex-col items-center justify-center p-6">
                    <!-- Кнопка play -->
                    <div class="mb-6">
                      <svg class="w-24 h-24 text-white group-hover:scale-110 transition-transform duration-300" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M8 5v14l11-7z"/>
                      </svg>
                    </div>
                    
                    <!-- Информация о видео (в центре под кнопкой) -->
                    <div class="text-center space-y-2 max-w-md">
                      <p class="text-white text-xl font-semibold">{video.title}</p>
                      <p class="text-white/80 text-base">{video.description}</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</InfoLayout>

<style>
  /* Стили для скроллбара */
  .overflow-x-auto {
    scrollbar-width: thin;
    scrollbar-color: #3f3f46 #18181b;
  }

  .overflow-x-auto::-webkit-scrollbar {
    height: 8px;
  }

  .overflow-x-auto::-webkit-scrollbar-track {
    background: #18181b;
    border-radius: 4px;
  }

  .overflow-x-auto::-webkit-scrollbar-thumb {
    background: #3f3f46;
    border-radius: 4px;
  }

  .overflow-x-auto::-webkit-scrollbar-thumb:hover {
    background: #52525b;
  }

  /* Улучшенная защита от выделения */
  .no-selection {
    user-select: none !important;
    -webkit-user-select: none !important;
    -moz-user-select: none !important;
    -ms-user-select: none !important;
  }

  /* Запрет выделения и перетаскивания изображений */
  img {
    user-select: none !important;
    -webkit-user-select: none !important;
    -moz-user-select: none !important;
    -ms-user-select: none !important;
    pointer-events: none;
    -webkit-user-drag: none;
    -khtml-user-drag: none;
    -moz-user-drag: none;
    -o-user-drag: none;
  }

  /* Защита для всех элементов */
  * {
    -webkit-touch-callout: none;
    -webkit-tap-highlight-color: transparent;
  }

  /* Стили для изображений с ошибкой загрузки */
  img {
    background: linear-gradient(135deg, #3f3f46 0%, #18181b 100%);
  }

  /* Анимация для видео контейнера */
  .video-item {
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .video-item:hover {
    transform: scale(1.02);
    z-index: 10;
  }

  .video-container {
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .video-container:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.3), 0 10px 10px -5px rgba(0, 0, 0, 0.2);
  }
</style>

<script is:inline>
  // Блокировка контекстного меню на всей странице
  document.addEventListener('contextmenu', function(e) {
    e.preventDefault();
    return false;
  }, { capture: true });

  // Блокировка сочетаний клавиш для сохранения
  document.addEventListener('keydown', function(e) {
    // Ctrl+S, Ctrl+Shift+S, Cmd+S
    if ((e.ctrlKey || e.metaKey) && (e.key === 's' || e.key === 'S')) {
      e.preventDefault();
      return false;
    }
    
    // PrintScreen
    if (e.key === 'PrintScreen' || e.key === 'PrintScreen' || e.keyCode === 44) {
      e.preventDefault();
      return false;
    }
  }, { capture: true });

  // Блокировка drag & drop
  document.addEventListener('dragstart', function(e) {
    e.preventDefault();
    return false;
  }, { capture: true });

  document.addEventListener('drop', function(e) {
    e.preventDefault();
    return false;
  }, { capture: true });

  // Блокировка выделения текста
  document.addEventListener('selectstart', function(e) {
    e.preventDefault();
    return false;
  }, { capture: true });

  // Блокировка копирования через контекстное меню
  document.addEventListener('copy', function(e) {
    e.preventDefault();
    return false;
  }, { capture: true });

  // Функция для воспроизведения видео
  function playVideo(container, videoId) {
    const iframe = document.createElement('iframe');
    iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0&modestbranding=1`;
    iframe.style.position = 'absolute';
    iframe.style.top = '0';
    iframe.style.left = '0';
    iframe.style.width = '100%';
    iframe.style.height = '100%';
    iframe.style.border = '0';
    iframe.style.borderRadius = '0.5rem';
    iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
    iframe.allowFullscreen = true;
    iframe.title = 'YouTube video player';
    
    container.innerHTML = '';
    container.appendChild(iframe);
  }

  // Инициализация кликов по видео
  document.addEventListener('DOMContentLoaded', function() {
    const videoContainers = document.querySelectorAll('[data-video-id]');
    
    videoContainers.forEach(container => {
      container.addEventListener('click', function(e) {
        e.preventDefault();
        const videoId = this.dataset.videoId;
        
        if (videoId) {
          playVideo(this, videoId);
          // Убираем обработчик после первого клика
          this.removeEventListener('click', arguments.callee);
        }
      });
    });
  });

  // Функция для обработки ошибок загрузки изображений
  document.addEventListener('DOMContentLoaded', function() {
    const images = document.querySelectorAll('img[src*="youtube.com"]');
    
    images.forEach(img => {
      img.addEventListener('error', function() {
        // Если hqdefault не загрузился, пробуем mqdefault
        if (this.src.includes('hqdefault.jpg')) {
          this.src = this.src.replace('hqdefault.jpg', 'mqdefault.jpg');
        } else if (this.src.includes('mqdefault.jpg')) {
          // Если mqdefault не загрузился, пробуем default
          this.src = this.src.replace('mqdefault.jpg', 'default.jpg');
        } else {
          // Если ничего не работает, показываем SVG placeholder
          this.src = 'data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iNDgwIiBoZWlnaHQ9IjM2MCIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj48cmVjdCB3aWR0aD0iMTAwJSIgaGVpZ2h0PSIxMDAlIiBmaWxsPSIjM2YzZjQ2Ii8+PHBhdGggZD0iTTggNXYxNGwxMS03eiIgZmlsbD0iI2ZmZiIgdHJhbnNmb3JtPSJ0cmFuc2xhdGUoMjMwIDE2MCkiLz48L3N2Zz4=';
        }
      });
    });
  });
</script>
