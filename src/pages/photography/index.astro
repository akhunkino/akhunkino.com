    { src: "/images/photography/projects/russia/russia15.jpg", alt: "Russia 15" },
  ],
};

// Функция для получения случайной категории
function getRandomCategory(categories) {
  const keys = Object.keys(categories);
  const randomIndex = Math.floor(Math.random() * keys.length);
  return keys[randomIndex];
}

// Если в URL нет категории - выбираем случайную
const photoSubcategory = photoSubcategoryFromURL || getRandomCategory(photos);

// Описания категорий
const categoryDescriptions = {
  alsib: "To study the experience of building the route, its historical and cultural heritage, and to honor the pilots who flew the planes in difficult conditions and the local residents who built and maintained the airfields, the Russian Geographical Society and the Russian Ministry of Defense organized a large-scale expedition to survey the facilities of the Alaska - Siberia Air route.",
  "small rig": "Documentary behind-the-scenes shooting of the video commercial production for the SmallRig and Transformers collaboration. The frame captures industrial aesthetics, high-tech elements, and the live atmosphere of the production set. Black-and-white imagery conveys textures, light, and working moments without unnecessary visual noise.",
  "wild wind": "On an overcast day, colors fade away, making room for textures and emotions. We shot this series against the backdrop of windmills, where the industrial landscape met living plasticity. The light from the flash works here like a brush—it pulls the heroine out of the gloom, emphasizing her detachment and depth.\n\nThese portraits are an attempt to capture silence in a place where the wind constantly turns the blades.",
  street: "Photography isn't merely recording reality — it's the art of constructing visual relationships that transform fact into self-evident truth.",
  russia: "Behind me are tens of thousands of kilometers and hundreds of forgotten dots on the map. I was searching for the real Russia and found it in the places left behind the windows of high-speed trains and federal highways.",
};

// Информация о клиентах и годах для каждой категории
const categoryInfo = {
  alsib: {
    client: "Russian Geographical Society",
    year: "2021"
  },
  "small rig": {
    client: "SmallRig China",
    year: "2025"
  },
  "wild wind": {
    client: "",
    year: ""
  },
  street: {
    client: "",
    year: ""
  },
  russia: {
    client: "",
    year: "2021"
  },
};

// Функция перемешивания
function shuffleArray(array) {
  const shuffled = [...array];
  for (let i = shuffled.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
  }
  return shuffled;
}

// Перемешиваем все категории один раз
const shuffledPhotos = {};
for (const [key, arr] of Object.entries(photos)) {
  shuffledPhotos[key] = shuffleArray(arr);
}

// Активная категория с fallback
const validCategories = Object.keys(photos);
const activeCategory = validCategories.includes(photoSubcategory)
  ? photoSubcategory
  : getRandomCategory(photos); // Если категория из URL невалидна, тоже выбираем случайную
---

<InfoLayout>
  <!-- Основной контейнер с защитой от выделения -->
  <div class="p-4 sm:pt-8 sm:px-12 pb-20 min-h-dvh no-selection">
    <H1>Photography</H1>

    <!-- Кнопки категорий -->
    <div class="px-4 sm:px-12 mb-4 mt-8">
      <div class="flex items-center gap-4 flex-wrap">
        {validCategories.map((cat) => {
          const label =
            cat === "alsib" ? "The Alaska-Siberia Air Bridge" :
            cat === "small rig" ? "Small Rig x Transformers" :
            cat === "wild wind" ? "Wild Wind" :
            cat === 'street' ? 'Street Photo' :
            cat === 'russia' ? 'Stills from Russia' : cat;

          return (
            <a
              href={`/photography?sub=${cat}`}
              class={clsx(
                'px-4 py-2 text-sm rounded-full transition-all duration-300 border no-selection',
                activeCategory === cat
                  ? 'bg-white text-black border-white'
                  : 'bg-zinc-800 text-zinc-300 hover:bg-zinc-700 border-transparent'
              )}
            >
              {label}
            </a>
          );
        })}
      </div>
    </div>

    <!-- Описание активной категории -->
    <div class="px-4 sm:px-12 mb-8">
      <div class="max-w-3xl">
        <p class="text-zinc-500 text-lg leading-relaxed whitespace-pre-line no-selection">
          {categoryDescriptions[activeCategory]}
        </p>
      </div>
    </div>

    <!-- Простой горизонтальный коллаж -->
    <div class="px-4 sm:px-12">
      <div class="overflow-x-auto">
        <div class="flex gap-4 pb-4 min-w-max">
          {shuffledPhotos[activeCategory].map((photo, index) => (
            <div
              key={`${activeCategory}-${index}`}
              class="flex-shrink-0 no-selection"
            >
              <div class="relative overflow-hidden rounded-lg bg-zinc-800 no-selection">
                <!-- Контейнер для изображения с сохранением пропорций -->
                <div class="w-auto h-[550px] flex items-center justify-center no-selection">
                  <img
                    src={photo.src}
                    alt={photo.alt}
                    class="max-h-full max-w-full object-contain no-selection"
                    loading="lazy"
                    decoding="async"
                    onContextMenu={(e) => e.preventDefault()}
                    draggable={false}
                  />
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Информация о клиенте и годе (только для категорий с данными) -->
    {(categoryInfo[activeCategory].client || categoryInfo[activeCategory].year) && (
      <div class="px-4 sm:px-12 mt-8">
        <div class="max-w-3xl">
          <div class="flex flex-col sm:flex-row gap-4 sm:gap-8 text-zinc-500 text-sm">
            {categoryInfo[activeCategory].client && (
              <div class="flex items-center gap-2">
                <span class="font-medium">Client:</span>
                <span>{categoryInfo[activeCategory].client}</span>
              </div>
            )}
            {categoryInfo[activeCategory].year && (
              <div class="flex items-center gap-2">
                <span class="font-medium">Year:</span>
                <span>{categoryInfo[activeCategory].year}</span>
              </div>
            )}
          </div>
        </div>
      </div>
    )}
  </div>
</InfoLayout>

<style>
  /* Стили для скроллбара */
  .overflow-x-auto {
    scrollbar-width: thin;
    scrollbar-color: #3f3f46 #18181b;
  }

  .overflow-x-auto::-webkit-scrollbar {
    height: 8px;
  }

  .overflow-x-auto::-webkit-scrollbar-track {
    background: #18181b;
    border-radius: 4px;
  }

  .overflow-x-auto::-webkit-scrollbar-thumb {
    background: #3f3f46;
    border-radius: 4px;
  }

  .overflow-x-auto::-webkit-scrollbar-thumb:hover {
    background: #52525b;
  }

  /* Улучшенная защита от выделения */
  .no-selection {
    user-select: none !important;
    -webkit-user-select: none !important;
    -moz-user-select: none !important;
    -ms-user-select: none !important;
  }

  /* Запрет выделения и перетаскивания изображений */
  img {
    user-select: none !important;
    -webkit-user-select: none !important;
    -moz-user-select: none !important;
    -ms-user-select: none !important;
    pointer-events: none;
    -webkit-user-drag: none;
    -khtml-user-drag: none;
    -moz-user-drag: none;
    -o-user-drag: none;
  }

  /* Защита для всех элементов */
  * {
    -webkit-touch-callout: none;
    -webkit-tap-highlight-color: transparent;
  }

  /* Разрешаем выделение для интерактивных элементов если нужно */
  input, textarea {
    user-select: text !important;
    -webkit-user-select: text !important;
  }
</style>

<script is:inline>
  // Блокировка контекстного меню на всей странице
  document.addEventListener('contextmenu', function(e) {
    e.preventDefault();
    return false;
  }, { capture: true });

  // Блокировка сочетаний клавиш для сохранения
  document.addEventListener('keydown', function(e) {
    // Ctrl+S, Ctrl+Shift+S, Cmd+S
    if ((e.ctrlKey || e.metaKey