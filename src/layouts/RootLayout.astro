---
import "../styles/global.css";
import "../styles/fonts.css";
import { ClientRouter } from 'astro:transitions';
import LoadingIndicator from "astro-loading-indicator/component"

const { title, description } = Astro.props;

// Измените на свои данные
const defaultTitle = "Rustem Akhunov | Akhunkino";
const defaultDescription = "Akhunkino";
---

<!doctype html>
<html lang="en">
        <head>
                <meta charset="UTF-8" />
                <meta name="viewport" content="width=device-width" />
                <link rel="icon" type="image/png" href="/logo.png" />

                {/* Добавьте для Apple устройств (опционально) */}
                <link rel="apple-touch-icon" href="/logo.png" />

                <meta name="generator" content={Astro.generator} />
                <title>{title ?? defaultTitle}</title>
                <meta name="description" content={description ?? defaultDescription} />

                {/* Измените URL на свой */}
                <meta property="og:url" content="https://www.akhunkino.com/" />
                <meta property="og:type" content="website" />
                <meta property="og:title" content={defaultTitle} />
                <meta property="og:description" content={defaultDescription} />
                <meta property="og:image" content="/social-image.jpg" />

                <ClientRouter />
                <LoadingIndicator color="#f4f4f5" height="2px" />

        </head>
        <body class="font-sans min-h-screen bg-zinc-900">
                <slot />
        </body>
</html>

<style>
        html,
        body {
                margin: 0;
                width: 100%;
                height: 100%;
        }
</style>
